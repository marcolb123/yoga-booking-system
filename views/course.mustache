
{{> head}}
{{> header}}

<article>
  <h1>{{course.title}}</h1>
  <p class="muted">
    Level: {{course.level}} &bull; Type: {{course.type}} {{#course.allowDropIn}}&bull; Drop-in available{{/course.allowDropIn}}
  </p>
  <p>{{course.description}}</p>
  <div class="kv">
    <dt>Dates</dt><dd>{{course.startDate}} &ndash; {{course.endDate}}</dd>
    {{#course.location}}<dt>Location</dt><dd>{{course.location}}</dd>{{/course.location}}
    {{#course.price}}<dt>Price</dt><dd>{{course.price}}</dd>{{/course.price}}
  </div>

  {{#user}}
  <section>
    <h2>Book the full course</h2>
    <form action="/courses/{{course.id}}/book" method="post">
      <button class="btn primary" type="submit">Book full course</button>
    </form>
  </section>
  {{/user}}
  {{^user}}
  <p><a class="btn primary" href="/auth/login">Login to book</a></p>
  {{/user}}

  <section>
    <h2>Sessions</h2>
    <table class="table">
      <thead>
        <tr><th>Start</th><th>End</th><th>Capacity</th><th>Booked</th><th>Remaining</th><th></th></tr>
      </thead>
      <tbody>
        {{#sessions}}
        <tr>
          <td>{{start}}</td>
          <td>{{end}}</td>
          <td>{{capacity}}</td>
          <td>{{booked}}</td>
          <td>{{remaining}}</td>
          <td>
            {{#../course.allowDropIn}}
            {{#../user}}
            <form method="post" action="/sessions/{{id}}/book">
              <button class="btn" type="submit" {{#isFull}}disabled{{/isFull}}>Book this session</button>
            </form>
            {{/../user}}
            {{^../user}}
              <a class="btn" href="/auth/login">Login to book</a>
            {{/../user}}
            {{/../course.allowDropIn}}
            {{^../course.allowDropIn}}
              <span class="muted">Drop-ins disabled</span>
            {{/../course.allowDropIn}}
          </td>
        </tr>
        {{/sessions}}
      </tbody>
    </table>
  </section>
</article>

{{> footer}}

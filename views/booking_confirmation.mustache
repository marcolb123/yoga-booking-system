
{{> head}}
{{> header}}

<h1>Booking Confirmation</h1>
<p>Your booking has been created.</p>

<dl class="kv">
  <dt>ID</dt><dd>{{booking.id}}</dd>
  <dt>Type</dt><dd>{{booking.type}}</dd>
  <dt>Status</dt><dd><span class="badge {{booking.statusClass}}">{{booking.status}}</span></dd>
  <dt>Created</dt><dd>{{booking.createdAt}}</dd>
</dl>

<div class="actions">
  <a class="btn primary" href="/my-bookings">My Bookings</a>
  <a class="btn" href="/courses">Browse more courses</a>
</div>

{{> footer}}
